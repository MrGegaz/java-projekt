<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="hr.faks.videogametracker.gui.MainController"
            prefWidth="1000.0" prefHeight="600.0">

    <top>
        <VBox spacing="5">
            <ToolBar>
                <Button fx:id="btnDodaj" text="Dodaj" />
                <Button fx:id="btnUredi" text="Uredi" />
                <Button fx:id="btnObrisi" text="Obriši" />
                <Separator orientation="VERTICAL"/>
                <Label text="Ukupno igara:" />
                <Label fx:id="lblUkupno" text="0" />
                <Button fx:id="btnPokreni" text="Pokreni igru" visible="false" onAction="#pokreniIgru" />
            </ToolBar>

            <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 5 10 5 10;">
                <Label text="Pretraga:" />
                <TextField fx:id="txtPretraga" promptText="Unesi naslov" prefWidth="200" />

                <Label text="Platforma:" />
                <ComboBox fx:id="cmbPlatforma" prefWidth="150" />

                <Label text="Godina:" />
                <ComboBox fx:id="cmbGodina" prefWidth="150" />

                <Button fx:id="btnFiltriraj" text="Primijeni filtere" />
                <Button fx:id="btnResetiraj" text="Resetiraj" />
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <padding>
                <Insets top="10.0" right="10.0" bottom="10.0" left="10.0"/>
            </padding>

            <TableView fx:id="tableViewIgre" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNaslov" text="Naslov igre" prefWidth="300"/>
                    <TableColumn fx:id="colPlatforma" text="Platforma" prefWidth="200"/>
                    <TableColumn fx:id="colZanr" text="Žanr" prefWidth="200"/>
                    <TableColumn fx:id="colGodina" text="Godina izlaska" prefWidth="150"/>
                    <TableColumn fx:id="colInstalirana" text="Instalirana" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
