<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="hr.faks.videogametracker.gui.DodajIgruController"
      spacing="10" alignment="TOP_LEFT" prefWidth="400" prefHeight="300">

    <children>
        <Label text="Dodaj novu igru" style="-fx-font-size: 16px; -fx-font-weight: bold;" />

        <TextField fx:id="tfNaslov" promptText="Naslov igre"/>
        <TextField fx:id="tfGodina" promptText="Godina izlaska"/>
        <ComboBox fx:id="cbPlatforma" promptText="Odaberi platformu"/>
        <TextField fx:id="tfZanr" promptText="Žanr"/>

        <HBox spacing="10">
            <Button fx:id="btnSpremi" text="Spremi" />
            <Button fx:id="btnOdustani" text="Odustani" />
        </HBox>
    </children>

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>
</VBox>
